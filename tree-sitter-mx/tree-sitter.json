{
  "grammars": [
    {
      "name": "mx",
      "camelcase": "Mx",
      "scope": "source.mx",
      "path": ".",
      "file-types": [
        "mx"
      ],
      "highlights": "queries/highlights.scm",
      "locals": "queries/locals.scm",
      "injection-regex": "^mx$"
    }
  ],
  "metadata": {
    "version": "0.0.1",
    "license": "MIT",
    "description": "Mx grammar for tree-sitter",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-mx"
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false
  }
}
